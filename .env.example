# ============================================
# AIRSTAY PROPERTIES — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.

# --- HOSTAWAY ---
# Get these from your Hostaway dashboard → Settings → API
VITE_HOSTAWAY_ACCOUNT_ID=your_account_id_here
VITE_HOSTAWAY_API_KEY=your_api_key_here
VITE_HOSTAWAY_BASE_URL=https://api.hostaway.com/v1

# --- STRIPE ---
# Get from stripe.com → Developers → API Keys
# Use TEST keys during development, LIVE keys for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# This one is server-side only — put it in Vercel environment variables, NEVER in frontend code
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# --- APP ---
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Airstay Properties
